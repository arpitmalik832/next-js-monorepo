{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "extends": "nx/presets/npm.json",
  "npmScope": "next-js-monorepo",
  "version": "0.0.0",
  "tasksRunnerOptions": {
    "default": {
      "runner": "nx/tasks-runners/default",
      "options": {
        "cacheableOperations": [
          "build",
          "build:beta",
          "build:prod",
          "e2e-run",
          "e2e-run:pre-commit",
          "knip:prod:check-files",
          "lint",
          "lint:fix",
          "storybook:build:prod",
          "test",
          "test:coverage",
          "test:coverage:silent:quick"
        ],
        "parallel": 1,
        "maxParallel": 1
      }
    }
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"]
    },
    "test": {
      "inputs": ["default", "^default", "{workspaceRoot}/jest.preset.js"],
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "{workspaceRoot}/jest.config.js",
        "setupFile": "{workspaceRoot}/jest.setup.js"
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    },
    "lint": {
      "inputs": ["default", "{workspaceRoot}/.eslintrc.json"]
    }
  },
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "packages"
  }
}
